---
const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<div class="left">
			<span class="mark">DCD</span>
			<span class="copy">&copy; {year} Digital Creative Department</span>
		</div>
		<div class="right">
			<a href="/archive">Archive</a>
			<a href="/rss.xml">RSS</a>
		</div>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		background: var(--bg);
	}
	.inner {
		max-width: var(--max);
		margin: 0 auto;
		padding: 2rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		font-size: 0.9rem;
		color: var(--text-muted);
	}
	.left {
		display: flex;
		align-items: center;
		gap: 0.7rem;
	}
	.mark {
		font-family: var(--mono);
		font-weight: 700;
		font-size: 0.85rem;
		padding: 0.15rem 0.4rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--accent);
	}
	.right {
		display: flex;
		gap: 1rem;
	}
	.right a {
		color: var(--text-dim);
		border: none;
	}
	.right a:hover {
		color: var(--accent);
		border: none;
	}
</style>
