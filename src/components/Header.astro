---
import HeaderLink from "./HeaderLink.astro";
import { SITE_SHORT } from "../consts";
---

<header>
	<nav>
		<a href="/" class="brand">
			<span class="mark">{SITE_SHORT}</span>
			<span class="full">Digital Creative Department</span>
		</a>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/archive">Archive</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: rgba(13, 14, 18, 0.85);
		backdrop-filter: saturate(140%) blur(12px);
		-webkit-backdrop-filter: saturate(140%) blur(12px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		max-width: var(--max);
		margin: 0 auto;
		padding: 1rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}
	.brand {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		color: var(--text);
		border: none;
		text-decoration: none;
	}
	.brand:hover {
		border: none;
	}
	.brand .mark {
		font-family: var(--mono);
		font-weight: 700;
		font-size: 0.95rem;
		letter-spacing: 0.05em;
		padding: 0.2rem 0.45rem;
		background: var(--accent);
		color: #0d0e12;
		border-radius: 4px;
	}
	.brand .full {
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--text);
		letter-spacing: -0.01em;
	}
	.links {
		display: flex;
		gap: 0.4rem;
	}
	@media (max-width: 540px) {
		.brand .full {
			display: none;
		}
		nav {
			padding: 0.85rem 1rem;
		}
	}
</style>
