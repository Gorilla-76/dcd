---
import { type CollectionEntry, getCollection, render } from "astro:content";
import NewsletterPost from "../../layouts/NewsletterPost.astro";

export async function getStaticPaths() {
	const issues = await getCollection("newsletter");
	return issues.map((issue) => ({
		params: { slug: issue.id },
		props: issue,
	}));
}
type Props = CollectionEntry<"newsletter">;

const issue = Astro.props;
const { Content } = await render(issue);
---

<NewsletterPost {...issue.data}>
	<Content />
</NewsletterPost>
